# -- Anthropic -----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -- ElevenLabs (Wes voice synthesis) ------------------------------------------
# Free tier: 10k chars/month, no CC required.
# Sign up at https://elevenlabs.io/app/sign-up then copy your key from
# https://elevenlabs.io/app/developers/api-keys
ELEVENLABS_API_KEY=sk_...

# Optional overrides (defaults shown):
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # Adam premade -- free-tier
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# -- Twilio (Wes voice calls) --------------------------------------------------
# Trial account: sign up at https://www.twilio.com/try-twilio ($15 credit)
TWILIO_SID=AC...
TWILIO_AUTH_TOKEN=...
# (legacy TWILIO_TOKEN still accepted with deprecation warning — set PYTHONWARNINGS=default::DeprecationWarning to surface it)
TWILIO_FROM=+1...
TWILIO_TO_NUMBER=+1...

# -- Demo phone mode -----------------------------------------------------------
# dashboard = show call in PWA, no real phone call placed (default/safe)
# twilio    = place a real Twilio call (requires TWILIO_* + CLOUDFLARE_TUNNEL_URL)
DEMO_PHONE_MODE=dashboard

# For real Twilio calls, expose runtime/voice/ via a public URL:
# CLOUDFLARE_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# -- MQTT broker ---------------------------------------------------------------
# Defaults to embedded amqtt broker if not set
MQTT_URL=mqtt://localhost:1883

# -- Drone backend -------------------------------------------------------------
# sitl = ArduPilot SITL simulator (default)
# mavlink = real drone via MAVLink
DRONE_BACKEND=sitl
