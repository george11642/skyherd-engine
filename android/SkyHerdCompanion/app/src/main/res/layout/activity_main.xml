<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#1A1A2E">

    <!-- App title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="22sp"
        android:textColor="#E0E0E0"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <!-- DJI SDK registration status -->
    <TextView
        android:id="@+id/tvSdkStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="DJI SDK: checking..."
        android:textSize="14sp"
        android:textColor="#80CBC4"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Drone serial / connection -->
    <TextView
        android:id="@+id/tvDroneSerial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Drone: not connected"
        android:textSize="14sp"
        android:textColor="#80CBC4"
        app:layout_constraintTop_toBottomOf="@id/tvSdkStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#333366"
        app:layout_constraintTop_toBottomOf="@id/tvDroneSerial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- MQTT broker URL input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilBrokerUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_broker_url"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="#5C6BC0"
        app:hintTextColor="#9FA8DA"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBrokerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textColor="#E0E0E0"
            android:hint="tcp://192.168.1.100:1883" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Connect button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_connect"
        android:textColor="#FFFFFF"
        app:backgroundTint="#3F51B5"
        app:layout_constraintTop_toBottomOf="@id/tilBrokerUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- MQTT status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Status: idle"
        android:textSize="13sp"
        android:textColor="#9FA8DA"
        app:layout_constraintTop_toBottomOf="@id/btnConnect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
