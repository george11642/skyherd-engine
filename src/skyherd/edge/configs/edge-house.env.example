# edge-house.env.example — Pi 4 (sole vision edge node)
# Deploy to: /etc/skyherd/edge.env on the ranch-house Pi.
# Covers ALL trough cameras (1-6). Environmental telemetry (water tank, weather)
# runs on a separate Galileo node — see docs/HARDWARE_GALILEO.md.
# Provision with: ssh pi@edge-house 'bash -s' < scripts/provision-edge.sh edge-house "trough_1,trough_2,trough_3,trough_4,trough_5,trough_6"

# ---- Required ----

# Ranch identifier — must match skyherd-engine RANCH_ID.
RANCH_ID=ranch_a

# MQTT broker URL — IP of the laptop/server running Mosquitto.
MQTT_URL=mqtt://192.168.1.100:1883

# ---- Node identity ----

# Unique name for this Pi on the MQTT bus and dashboard.
EDGE_ID=edge-house

# Comma-separated trough IDs that this Pi is responsible for.
# This Pi is the single vision node and covers every trough camera on the ranch.
EDGE_TROUGH_IDS=trough_1,trough_2,trough_3,trough_4,trough_5,trough_6

# ---- Detector mode ----
# rule        — heuristic only, 0 ms, safe baseline, no model weights needed.
# megadetector — MegaDetector V6 via PytorchWildlife; ~3-5 s/frame on Pi 4 CPU.
# coral        — MegaDetector via Coral USB Accelerator; ~200 ms/frame (needs libedgetpu).
EDGE_DETECTOR_MODE=rule

# ---- Capture ----

# Seconds between captures.  10 s matches sim sensor cadence.
EDGE_CAPTURE_INTERVAL_S=10

# Camera backend: "auto" | "pi" | "mock".  Default: auto
# CAMERA_KIND=auto

# ---- Observability ----

# Heartbeat interval in seconds (published to edge_status topic).
# EDGE_HEARTBEAT_INTERVAL_S=30

# HTTP health-check port (0 = disabled).
# EDGE_HEALTHZ_PORT=8787

# Log level: DEBUG | INFO | WARNING | ERROR.
# LOG_LEVEL=INFO
