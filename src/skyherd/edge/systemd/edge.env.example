# /etc/skyherd/edge.env — SkyHerd Edge Watcher environment
# Copy to /etc/skyherd/edge.env and edit before enabling the service.
# sudo mkdir -p /etc/skyherd && sudo cp edge.env.example /etc/skyherd/edge.env

# ---- Required ----

# Ranch identifier — must match the ranch_id used by the central skyherd-engine
# instance so MQTT topic routing aligns.  Default: ranch_a
RANCH_ID=ranch_a

# MQTT broker URL — point at the laptop/server running Mosquitto.
# Replace 192.168.1.100 with the IP of the machine running skyherd-engine.
MQTT_URL=mqtt://192.168.1.100:1883

# ---- Optional ----

# Edge node identifier — defaults to the Pi's hostname.
# Override if you have multiple Pi cameras on the same ranch.
# EDGE_ID=pi_trough_1

# Capture interval in seconds.  Default: 10
# EDGE_CAPTURE_INTERVAL_S=10

# Camera backend: "auto" | "pi" | "mock".  Default: auto
# CAMERA_KIND=auto

# Log level: DEBUG | INFO | WARNING | ERROR.  Default: INFO
# LOG_LEVEL=INFO
