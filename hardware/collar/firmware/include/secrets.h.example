/**
 * secrets.h.example — copy to secrets.h and fill in your device credentials.
 *
 * secrets.h is gitignored — never commit real keys.
 *
 * How to obtain credentials:
 *   1. Run: python hardware/collar/provisioning/register-collar.py \
 *               --dev-eui <your-eui> --ranch ranch_a --cow-tag A001
 *   2. ChirpStack will generate APP_KEY on first OTAA join attempt if
 *      you leave it as the placeholder — copy from ChirpStack device detail.
 *   3. Paste values below and rebuild.
 */

#pragma once

// 8-byte EUI — printed on RAK3172 module label (16 hex chars, no colons)
#define DEV_EUI  "A8610A3453210A00"

// Application EUI (joinEUI) — from ChirpStack application settings
#define APP_EUI  "0000000000000000"

// 16-byte root key — from ChirpStack device OTAA credentials tab
#define APP_KEY  "00000000000000000000000000000000"

// Ranch + cow identifiers (used in downlink parsing, not LoRa credentials)
#define RANCH_ID  "ranch_a"
#define COW_TAG   "A001"
